{
  email {$CADDY_EMAIL}
}

{$SISTEQ_DOMAIN} {
  encode zstd gzip

  @nextStatic path /_next/static/*
  header @nextStatic Cache-Control "public, max-age=31536000, immutable"

  @publicAssets path /favicon.ico /robots.txt /sitemap.xml /manifest.json
  header @publicAssets Cache-Control "public, max-age=3600"

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
    X-Frame-Options "SAMEORIGIN"
  }

  reverse_proxy app:3000 {
    header_up X-Forwarded-Proto {scheme}
    header_up X-Forwarded-Host {host}
    header_up X-Real-IP {remote_host}
  }

  log {
    format json
  }
}

grafana.{$SISTEQ_DOMAIN} {
  encode zstd gzip
  reverse_proxy grafana:3000
  log {
    format json
  }
}
